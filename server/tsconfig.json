{
  "compilerOptions": {
    "target": "ES2022",

    "module": "CommonJS",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,

    "types": ["node"],

    "sourceMap": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}